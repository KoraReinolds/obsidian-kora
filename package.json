{
	"name": "obsidian-sample-plugin",
	"version": "1.0.0",
	"description": "This is a sample plugin for Obsidian (https://obsidian.md)",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"watch:mcp": "nodemon --watch ./mcp-server.ts --watch ./apps/obsidian-plugin/src/mcp --ext ts --exec \"bun build ./mcp-server.ts --outdir=./build --target=bun\"",
		"kora-auth": "cd kora-server && npm run build && npm run auth",
		"kora-server": "cd kora-server && npm run build && npm start",
		"kora-dev": "cd kora-server && npm run dev:dual",
		"dev-all": "concurrently \"npm run dev\" \"npm run watch:mcp\" \"npm run kora-dev\" --names \"obsidian,mcp,kora\" --prefix-colors \"blue,green,yellow\"",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint . --ext .ts,.js",
		"lint:fix": "eslint . --ext .ts,.js --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"precommit": "lint-staged",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:telegram": "vitest run packages/kora-core/src/chunking/__tests__",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"@vitest/coverage-v8": "^1.6.1",
		"builtin-modules": "3.3.0",
		"concurrently": "^9.2.0",
		"esbuild": "0.17.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.5",
		"nodemon": "^3.1.10",
		"obsidian": "latest",
		"prettier": "^3.6.2",
		"tslib": "2.4.0",
		"typescript": "4.7.4",
		"vitest": "^1.6.1"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.3",
		"@tailwindcss/postcss": "^4.2.2",
		"@vue/compiler-sfc": "^3.5.30",
		"autoprefixer": "^10.4.27",
		"cors": "^2.8.5",
		"crypto": "^1.0.1",
		"dotenv": "^17.2.0",
		"esbuild-plugin-vue3": "^0.5.1",
		"express": "^4.18.2",
		"input": "^1.0.1",
		"node-telegram-bot-api": "^0.66.0",
		"openai": "^4.68.4",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.2",
		"telegram": "^2.22.2",
		"uuid": "^11.1.0",
		"vue": "^3.5.30",
		"zod": "^3.25.67"
	},
	"lint-staged": {
		"*.{ts,js,mjs,cjs}": [
			"prettier --write",
			"eslint --fix --max-warnings=0"
		],
		"*.{vue,json,md,css}": "prettier --write"
	},
	"vitest": {
		"include": [
			"packages/kora-core/src/chunking/__tests__/**/*.spec.ts"
		],
		"exclude": [
			"mcp-obsidian/**",
			"kora-server/**"
		],
		"environment": "node",
		"coverage": {
			"provider": "v8",
			"reporter": [
				"text",
				"json",
				"html"
			],
			"include": [
				"packages/kora-core/src/chunking/**/*.ts"
			],
			"exclude": [
				"packages/kora-core/src/chunking/__tests__/**",
				"**/*.d.ts"
			],
			"thresholds": {
				"global": {
					"branches": 80,
					"functions": 80,
					"lines": 80,
					"statements": 80
				}
			}
		}
	}
}
